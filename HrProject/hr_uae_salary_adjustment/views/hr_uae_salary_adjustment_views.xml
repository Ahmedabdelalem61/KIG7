<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_uae_salary_adjustment_tree" model="ir.ui.view">
        <field name="name">hr.uae.salary.adjustment.list</field>
        <field name="model">hr.uae.salary.adjustment</field>
        <field name="arch" type="xml">
            <list decoration-info="state == 'to_approve'"
                  decoration-success="state == 'approved'"
                  decoration-muted="state in ('refused','done')">
                <field name="name"/>
                <field name="employee_id"/>
                <field name="kind"/>
                <field name="amount" sum="Total"/>
                <field name="currency_id" invisible="1"/>
                <field name="mode"/>
                <field name="date_from" optional="show"/>
                <field name="date_to" optional="hide"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="view_hr_uae_salary_adjustment_form" model="ir.ui.view">
        <field name="name">hr.uae.salary.adjustment.form</field>
        <field name="model">hr.uae.salary.adjustment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit"
                            invisible="state != 'draft'" class="btn-primary"/>
                    <button name="action_approve" type="object" string="Approve"
                            invisible="state != 'to_approve'" class="btn-primary"
                            groups="hr_uae_base.group_hr_uae_manager"/>
                    <button name="action_refuse" type="object" string="Refuse"
                            invisible="state != 'to_approve'"
                            groups="hr_uae_base.group_hr_uae_manager"/>
                    <button name="action_reset_to_draft" type="object" string="Reset to Draft"
                            invisible="state in ('draft','approved','done')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,to_approve,approved,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" readonly="state != 'draft'"/>
                            <field name="kind" readonly="state != 'draft'"/>
                            <field name="amount" readonly="state != 'draft'"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="mode" readonly="state != 'draft'"/>
                            <field name="target_payslip_id"
                                   invisible="mode != 'one_shot'"
                                   required="mode == 'one_shot'"
                                   readonly="state != 'draft'"/>
                            <field name="date_from"
                                   invisible="mode == 'one_shot'"
                                   required="mode in ('range','recurring')"
                                   readonly="state != 'draft'"/>
                            <field name="date_to"
                                   invisible="mode != 'range'"
                                   required="mode == 'range'"
                                   readonly="state != 'draft'"/>
                            <field name="recurring_interval"
                                   invisible="mode != 'recurring'"
                                   readonly="state != 'draft'"/>
                            <field name="recurring_until"
                                   invisible="mode != 'recurring'"
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes" nolabel="1" readonly="state == 'done'"/>
                    </group>
                    <group string="Approval" invisible="state in ('draft','to_approve')">
                        <field name="approver_id"/>
                        <field name="approved_on"/>
                        <field name="last_applied_period"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_uae_salary_adjustment_search" model="ir.ui.view">
        <field name="name">hr.uae.salary.adjustment.search</field>
        <field name="model">hr.uae.salary.adjustment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="kind"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="to_approve" string="To Approve" domain="[('state','=','to_approve')]"/>
                <filter name="approved" string="Approved" domain="[('state','=','approved')]"/>
                <group expand="0" string="Group By">
                    <filter name="g_emp" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="g_kind" string="Kind" context="{'group_by': 'kind'}"/>
                    <filter name="g_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_uae_salary_adjustment" model="ir.actions.act_window">
        <field name="name">Salary Adjustments</field>
        <field name="res_model">hr.uae.salary.adjustment</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
