<?xml version="1.0" encoding="utf-8"?>
<!-- noupdate="0": re-applied on every upgrade of this module, so the
     restriction survives upgrades of mail/calendar/website (which would
     otherwise restore their default menu groups). -->
<odoo>

    <!-- Hide the Discuss, Calendar and Website apps from everyone except
         administrators. Settings (base.menu_administration) is already
         restricted to base.group_system by core. -->
    <record id="mail.menu_root_discuss" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>
    <record id="calendar.mail_menu_calendar" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>
    <record id="website.menu_website_configuration" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base.group_system')])]"/>
    </record>

</odoo>
