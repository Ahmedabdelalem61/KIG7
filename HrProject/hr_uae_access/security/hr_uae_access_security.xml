<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== Category ===================== -->
    <record id="module_category_kig7_access" model="ir.module.category">
        <field name="name">KIG7 Access Rights</field>
        <field name="description">KIG7 business roles. A user holds exactly one role.</field>
        <field name="sequence">26</field>
    </record>

    <!-- ===================== Roles ========================
         The three roles are deliberately DISJOINT (no implication between
         them); mutual exclusivity is enforced by a constraint on res.users.
         Each role implies exactly the standard/project groups it needs and
         nothing more. -->

    <record id="group_kig7_hr_officer" model="res.groups">
        <field name="name">HR Officer</field>
        <field name="category_id" ref="module_category_kig7_access"/>
        <field name="implied_ids" eval="[(6, 0, [
            ref('base.group_user'),
            ref('hr.group_hr_user'),
            ref('hr_holidays.group_hr_holidays_user'),
            ref('hr_uae_base.group_hr_uae_user'),
        ])]"/>
        <field name="comment">Operational HR: employees, leaves, flights, documents,
            salary adjustments and the custom HR/payroll dashboards (read).
            No contracts, no configuration, no payroll computation, no accounting.</field>
    </record>

    <record id="group_kig7_hr_manager" model="res.groups">
        <field name="name">HR Manager</field>
        <field name="category_id" ref="module_category_kig7_access"/>
        <field name="implied_ids" eval="[(6, 0, [
            ref('base.group_user'),
            ref('hr_uae_base.group_hr_uae_manager'),
            ref('hr_contract.group_hr_contract_manager'),
            ref('hr_holidays.group_hr_holidays_manager'),
            ref('payroll.group_payroll_user'),
        ])]"/>
        <field name="comment">Full HR: configuration, approvals, reports, custom
            dashboards, contracts and payslip consultation. No accounting
            administration.</field>
    </record>

    <record id="group_kig7_payroll_manager" model="res.groups">
        <field name="name">Payroll &amp; Accounting Manager</field>
        <field name="category_id" ref="module_category_kig7_access"/>
        <field name="implied_ids" eval="[(6, 0, [
            ref('base.group_user'),
            ref('account.group_account_manager'),
            ref('hr_expense.group_hr_expense_manager'),
            ref('payroll.group_payroll_manager'),
            ref('hr.group_hr_user'),
            ref('hr_contract.group_hr_contract_manager'),
        ])]"/>
        <field name="comment">Accounting, payroll computation, expenses and the
            employee/contract data payroll needs. Deliberately implies NO
            hr_uae_base group: the custom HR/payroll dashboards and HR UAE Admin
            menus stay out of reach.</field>
    </record>

    <!-- ============ Block Discuss / Calendar / Website data ============
         ACLs for these models are granted to every internal user by the
         standard apps and cannot be revoked per group (ACLs are additive),
         and those apps define their own GROUP rules for base.group_user —
         group rules are OR-ed, so a per-group deny rule would be overridden.
         The supported way to deny the data is a GLOBAL rule with a
         conditional domain: globals are AND-ed with everything, so role
         members get an impossible domain while every other user keeps the
         standard behaviour. -->

    <record id="rule_kig7_block_discuss_channel" model="ir.rule">
        <field name="name">KIG7 roles: no Discuss channels</field>
        <field name="model_id" ref="mail.model_discuss_channel"/>
        <field name="domain_force">[(0, '=', 1)] if (
            user.has_group('hr_uae_access.group_kig7_hr_officer')
            or user.has_group('hr_uae_access.group_kig7_hr_manager')
            or user.has_group('hr_uae_access.group_kig7_payroll_manager')
        ) else [(1, '=', 1)]</field>
        <field name="groups" eval="[(5, 0, 0)]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_kig7_block_calendar_event" model="ir.rule">
        <field name="name">KIG7 roles: no Calendar events</field>
        <field name="model_id" ref="calendar.model_calendar_event"/>
        <field name="domain_force">[(0, '=', 1)] if (
            user.has_group('hr_uae_access.group_kig7_hr_officer')
            or user.has_group('hr_uae_access.group_kig7_hr_manager')
            or user.has_group('hr_uae_access.group_kig7_payroll_manager')
        ) else [(1, '=', 1)]</field>
        <field name="groups" eval="[(5, 0, 0)]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

    <record id="rule_kig7_block_website_page" model="ir.rule">
        <field name="name">KIG7 roles: no Website pages</field>
        <field name="model_id" ref="website.model_website_page"/>
        <field name="domain_force">[(0, '=', 1)] if (
            user.has_group('hr_uae_access.group_kig7_hr_officer')
            or user.has_group('hr_uae_access.group_kig7_hr_manager')
            or user.has_group('hr_uae_access.group_kig7_payroll_manager')
        ) else [(1, '=', 1)]</field>
        <field name="groups" eval="[(5, 0, 0)]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>

</odoo>
