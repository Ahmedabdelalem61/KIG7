<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_uae_flight_tree_project" model="ir.ui.view">
        <field name="name">hr.uae.flight.list.project</field>
        <field name="model">hr.uae.flight</field>
        <field name="inherit_id" ref="hr_uae_flights.view_hr_uae_flight_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="department_id" string="Project" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='project_allocation_id']" position="replace"/>
        </field>
    </record>

    <record id="view_hr_uae_flight_form_project" model="ir.ui.view">
        <field name="name">hr.uae.flight.form.project</field>
        <field name="model">hr.uae.flight</field>
        <field name="inherit_id" ref="hr_uae_flights.view_hr_uae_flight_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_allocation_id']" position="replace">
                <field name="department_id" string="Project" readonly="1"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_uae_flight_search_project" model="ir.ui.view">
        <field name="name">hr.uae.flight.search.project</field>
        <field name="model">hr.uae.flight</field>
        <field name="inherit_id" ref="hr_uae_flights.view_hr_uae_flight_search"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='employee_id']" position="after">
                <field name="department_id" string="Project"
                       filter_domain="['|', ('department_id.code', 'ilike', self), ('department_id.name', 'ilike', self)]"/>
            </xpath>
            <xpath expr="//filter[@name='group_project']" position="attributes">
                <attribute name="context">{'group_by': 'department_id'}</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_hr_uae_termination_tree_project" model="ir.ui.view">
        <field name="name">hr.uae.termination.list.project</field>
        <field name="model">hr.uae.termination</field>
        <field name="inherit_id" ref="hr_uae_termination.view_hr_uae_termination_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_allocation_id']" position="replace">
                <field name="department_id" string="Project"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_uae_termination_form_project" model="ir.ui.view">
        <field name="name">hr.uae.termination.form.project</field>
        <field name="model">hr.uae.termination</field>
        <field name="inherit_id" ref="hr_uae_termination.view_hr_uae_termination_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='project_allocation_id']" position="replace">
                <field name="department_id" string="Project"/>
            </xpath>
        </field>
    </record>

    <record id="view_hr_uae_termination_search_project" model="ir.ui.view">
        <field name="name">hr.uae.termination.search.project</field>
        <field name="model">hr.uae.termination</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="employee_id"/>
                <field name="department_id" string="Project"
                       filter_domain="['|', ('department_id.code', 'ilike', self), ('department_id.name', 'ilike', self)]"/>
                <field name="reason"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="active" string="Active" domain="[('state','=','active')]"/>
                <filter name="closed" string="Closed" domain="[('state','=','closed')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_project" string="Project" context="{'group_by': 'department_id'}"/>
                    <filter name="group_reason" string="Reason" context="{'group_by': 'reason'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="hr_uae_termination.action_hr_uae_termination" model="ir.actions.act_window">
        <field name="search_view_id" ref="view_hr_uae_termination_search_project"/>
    </record>

