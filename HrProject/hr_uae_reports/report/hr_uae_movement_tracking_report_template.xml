<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_movement_tracking_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Movement Tracking</h2>
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Employee</th>
                                <th>Movement Type</th>
                                <th>Date</th>
                                <th>Return Date</th>
                                <th>Notes</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="row">
                                <tr>
                                    <td><span t-esc="row.employee_id.name"/></td>
                                    <td><span t-field="row.movement_type"/></td>
                                    <td><span t-field="row.movement_date"/></td>
                                    <td><span t-field="row.return_date"/></td>
                                    <td><span t-esc="row.notes"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>
