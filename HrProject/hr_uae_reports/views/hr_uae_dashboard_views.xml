<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_uae_dashboard_form" model="ir.ui.view">
        <field name="name">hr.uae.dashboard.form</field>
        <field name="model">hr.uae.dashboard</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <div class="oe_title">
                        <h1>HR UAE Admin - Dashboard</h1>
                        <p class="text-muted">Live counts across employees, leaves, payroll, flights, visas and adjustments.</p>
                    </div>

                    <group string="Employees">
                        <group>
                            <field name="employees_total" string="Active Employees"/>
                            <field name="employees_active" string="Status: Active"/>
                            <field name="employees_on_vacation" string="On Vacation"/>
                            <field name="employees_on_special_permit" string="On Special Permit"/>
                        </group>
                        <group>
                            <field name="employees_sick" string="Sick Leave"/>
                            <field name="employees_resigned" string="Resigned"/>
                            <field name="employees_terminated" string="Terminated"/>
                        </group>
                    </group>

                    <group string="Visa Expiry">
                        <group>
                            <field name="visas_expiring_30" string="Expiring &lt; 30d"/>
                            <field name="visas_expiring_60" string="Expiring &lt; 60d"/>
                            <field name="visas_expiring_90" string="Expiring &lt; 90d"/>
                        </group>
                    </group>

                    <group string="Payroll &amp; Adjustments">
                        <group>
                            <field name="held_payslips" string="Held Payslips"/>
                            <field name="pending_adjustments" string="Adjustments to Approve"/>
                        </group>
                    </group>

                    <group string="Flights">
                        <group>
                            <field name="flights_open" string="Open Tickets"/>
                            <field name="flight_cost_total" widget="monetary"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_uae_dashboard" model="ir.actions.server">
        <field name="name">HR UAE Dashboard</field>
        <field name="model_id" ref="model_hr_uae_dashboard"/>
        <field name="state">code</field>
        <field name="code">action = model.action_open_dashboard()</field>
    </record>

</odoo>
