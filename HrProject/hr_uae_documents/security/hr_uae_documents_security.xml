<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="ir_rule_hr_uae_document_owner" model="ir.rule">
        <field name="name">UAE Document: owner sees own only</field>
        <field name="model_id" ref="model_hr_uae_document"/>
        <field name="domain_force">[('employee_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('hr_uae_base.group_hr_uae_document_owner'))]"/>
    </record>

    <record id="ir_rule_hr_uae_document_manager" model="ir.rule">
        <field name="name">UAE Document: HR Manager sees all (multi-company)</field>
        <field name="model_id" ref="model_hr_uae_document"/>
        <field name="domain_force">[('employee_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hr_uae_base.group_hr_uae_manager'))]"/>
    </record>

    <record id="ir_rule_hr_uae_document_finance" model="ir.rule">
        <field name="name">UAE Document: Finance read company</field>
        <field name="model_id" ref="model_hr_uae_document"/>
        <field name="domain_force">[('employee_id.company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('hr_uae_base.group_hr_uae_finance'))]"/>
    </record>

</odoo>
