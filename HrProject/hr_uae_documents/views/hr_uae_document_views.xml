<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_uae_document_tree" model="ir.ui.view">
        <field name="name">hr.uae.document.list</field>
        <field name="model">hr.uae.document</field>
        <field name="arch" type="xml">
            <list decoration-danger="expiry_state == 'expired'"
                  decoration-warning="expiry_state in ('expires_30','expires_60')"
                  decoration-info="expiry_state == 'expires_90'">
                <field name="employee_id"/>
                <field name="document_type"/>
                <field name="name"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
                <field name="days_to_expiry"/>
                <field name="expiry_state"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_hr_uae_document_form" model="ir.ui.view">
        <field name="name">hr.uae.document.form</field>
        <field name="model">hr.uae.document</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Passport #..."/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id"/>
                            <field name="document_type"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="issue_date"/>
                            <field name="expiry_date"/>
                            <field name="days_to_expiry"/>
                            <field name="expiry_state"/>
                        </group>
                    </group>
                    <group string="Files">
                        <field name="attachment_ids" widget="many2many_binary" nolabel="1"/>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_hr_uae_document_search" model="ir.ui.view">
        <field name="name">hr.uae.document.search</field>
        <field name="model">hr.uae.document</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="name"/>
                <field name="document_type"/>
                <filter name="expired" string="Expired" domain="[('expiry_state','=','expired')]"/>
                <filter name="expires_30" string="Expires &lt; 30d" domain="[('expiry_state','=','expires_30')]"/>
                <filter name="expires_90" string="Expires &lt; 90d" domain="[('expiry_state','in',('expires_30','expires_60','expires_90'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_type" string="Type" context="{'group_by': 'document_type'}"/>
                    <filter name="group_state" string="Expiry State" context="{'group_by': 'expiry_state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_uae_document" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">hr.uae.document</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
