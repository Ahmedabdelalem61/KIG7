<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="email_template_document_expiry" model="mail.template">
        <field name="name">HR UAE: Document Expiry Alert</field>
        <field name="model_id" ref="model_hr_uae_document"/>
        <field name="subject">Document expiring: {{ object.document_type.upper() }} for {{ object.employee_id.name }}</field>
        <field name="body_html" type="html">
            <div style="font-family:Arial,sans-serif">
                <p>Hello,</p>
                <p>
                    A document is expiring soon and requires action:
                </p>
                <ul>
                    <li><strong>Employee:</strong> <span t-out="object.employee_id.name"/></li>
                    <li><strong>Type:</strong> <span t-out="dict(object._fields['document_type'].selection).get(object.document_type)"/></li>
                    <li><strong>Document:</strong> <span t-out="object.name"/></li>
                    <li><strong>Expiry date:</strong> <span t-out="object.expiry_date"/></li>
                    <li><strong>Days to expiry:</strong> <span t-out="object.days_to_expiry"/></li>
                </ul>
                <p>Please review and renew if needed.</p>
            </div>
        </field>
        <field name="auto_delete" eval="True"/>
    </record>

</odoo>
