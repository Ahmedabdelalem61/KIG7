<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_contract_form_uae_currency" model="ir.ui.view">
        <field name="name">hr.contract.form.uae.currency</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="priority">100</field>
        <field name="arch" type="xml">

            <!-- 1. Currency selector before the wage. -->
            <xpath expr="//field[@name='wage']" position="before">
                <field name="company_currency_id" invisible="1"/>
                <field name="contract_currency_id" options="{'no_create': True}"
                       help="Currency the contract is denominated in. Enter the amounts in this currency below; the company-currency (AED) values are derived and shown read-only on the 'Converted (AED)' tab. Each payslip reconverts at its period-end rate. Define rates in Accounting → Currencies."/>
            </xpath>

            <!-- 2. Entered amounts (in the contract currency) = the editable
                 fields, shown where the wage normally is. -->
            <xpath expr="//field[@name='wage']" position="after">
                <field name="wage_foreign" string="Wage" widget="monetary"/>
                <field name="housing_allowance_foreign" string="Housing Allowance"
                       widget="monetary"/>
                <field name="transportation_allowance_foreign"
                       string="Transportation Allowance" widget="monetary"/>
                <field name="other_allowances_foreign" string="Other Allowances"
                       widget="monetary"/>
            </xpath>
            <xpath expr="//field[@name='annual_ticket_amount']" position="after">
                <field name="annual_ticket_amount_foreign" string="Annual Ticket Amount"
                       widget="monetary"/>
            </xpath>

            <!-- 3. The company-currency amounts are always derived: read-only and
                 hidden in their original position (shown on the AED tab below). -->
            <xpath expr="//field[@name='wage']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='housing_allowance']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='transportation_allowance']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='other_allowances']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='annual_ticket_amount']" position="attributes">
                <attribute name="readonly">1</attribute>
                <attribute name="force_save">1</attribute>
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- 4. Dedicated tab for read-only AED amounts, visible only when
                 the contract is in a non-company currency. Fields are listed
                 directly here (no position="move" — that is fragile). -->
            <xpath expr="//notebook" position="inside">
                <page string="Converted (AED)" name="hr_uae_aed_converted"
                      invisible="contract_currency_id == company_currency_id">
                    <group>
                        <group string="Monthly (Company Currency)">
                            <field name="wage" readonly="1" force_save="1"
                                   widget="monetary" string="Wage (AED)"/>
                            <field name="housing_allowance" readonly="1" force_save="1"
                                   widget="monetary" string="Housing Allowance (AED)"/>
                            <field name="transportation_allowance" readonly="1" force_save="1"
                                   widget="monetary" string="Transportation Allowance (AED)"/>
                            <field name="other_allowances" readonly="1" force_save="1"
                                   widget="monetary" string="Other Allowances (AED)"/>
                        </group>
                        <group string="Yearly (Company Currency)">
                            <field name="annual_ticket_amount" readonly="1" force_save="1"
                                   widget="monetary" string="Annual Ticket Amount (AED)"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
