<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        UAE working calendar. The proposal asks for "UAE working hours";
        a Sat-Thu, 8 hours/day schedule (48h/week) is the conservative
        default historically used in private-sector UAE companies.
        Companies can switch to Mon-Fri 4.5d post-2022 reform via UI.
    -->
    <record id="resource_calendar_uae" model="resource.calendar">
        <field name="name">UAE Standard (Sat-Thu, 8h)</field>
        <field name="hours_per_day">8.0</field>
        <field name="full_time_required_hours">48.0</field>
        <field name="tz">Asia/Dubai</field>
        <field name="two_weeks_calendar" eval="False"/>
    </record>

    <!-- Saturday -->
    <record id="resource_calendar_attendance_uae_sat_morning" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Saturday Morning</field>
        <field name="dayofweek">5</field>
        <field name="hour_from">8.0</field>
        <field name="hour_to">12.0</field>
        <field name="day_period">morning</field>
    </record>
    <record id="resource_calendar_attendance_uae_sat_afternoon" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Saturday Afternoon</field>
        <field name="dayofweek">5</field>
        <field name="hour_from">13.0</field>
        <field name="hour_to">17.0</field>
        <field name="day_period">afternoon</field>
    </record>
    <!-- Sunday -->
    <record id="resource_calendar_attendance_uae_sun_morning" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Sunday Morning</field>
        <field name="dayofweek">6</field>
        <field name="hour_from">8.0</field>
        <field name="hour_to">12.0</field>
        <field name="day_period">morning</field>
    </record>
    <record id="resource_calendar_attendance_uae_sun_afternoon" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Sunday Afternoon</field>
        <field name="dayofweek">6</field>
        <field name="hour_from">13.0</field>
        <field name="hour_to">17.0</field>
        <field name="day_period">afternoon</field>
    </record>
    <!-- Monday -->
    <record id="resource_calendar_attendance_uae_mon_morning" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Monday Morning</field>
        <field name="dayofweek">0</field>
        <field name="hour_from">8.0</field>
        <field name="hour_to">12.0</field>
        <field name="day_period">morning</field>
    </record>
    <record id="resource_calendar_attendance_uae_mon_afternoon" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Monday Afternoon</field>
        <field name="dayofweek">0</field>
        <field name="hour_from">13.0</field>
        <field name="hour_to">17.0</field>
        <field name="day_period">afternoon</field>
    </record>
    <!-- Tuesday -->
    <record id="resource_calendar_attendance_uae_tue_morning" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Tuesday Morning</field>
        <field name="dayofweek">1</field>
        <field name="hour_from">8.0</field>
        <field name="hour_to">12.0</field>
        <field name="day_period">morning</field>
    </record>
    <record id="resource_calendar_attendance_uae_tue_afternoon" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Tuesday Afternoon</field>
        <field name="dayofweek">1</field>
        <field name="hour_from">13.0</field>
        <field name="hour_to">17.0</field>
        <field name="day_period">afternoon</field>
    </record>
    <!-- Wednesday -->
    <record id="resource_calendar_attendance_uae_wed_morning" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Wednesday Morning</field>
        <field name="dayofweek">2</field>
        <field name="hour_from">8.0</field>
        <field name="hour_to">12.0</field>
        <field name="day_period">morning</field>
    </record>
    <record id="resource_calendar_attendance_uae_wed_afternoon" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Wednesday Afternoon</field>
        <field name="dayofweek">2</field>
        <field name="hour_from">13.0</field>
        <field name="hour_to">17.0</field>
        <field name="day_period">afternoon</field>
    </record>
    <!-- Thursday -->
    <record id="resource_calendar_attendance_uae_thu_morning" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Thursday Morning</field>
        <field name="dayofweek">3</field>
        <field name="hour_from">8.0</field>
        <field name="hour_to">12.0</field>
        <field name="day_period">morning</field>
    </record>
    <record id="resource_calendar_attendance_uae_thu_afternoon" model="resource.calendar.attendance">
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="name">Thursday Afternoon</field>
        <field name="dayofweek">3</field>
        <field name="hour_from">13.0</field>
        <field name="hour_to">17.0</field>
        <field name="day_period">afternoon</field>
    </record>

    <!-- Apply UAE defaults to UAE-based companies on install. -->
    <function model="res.company" name="_hr_uae_apply_defaults"/>

</odoo>
