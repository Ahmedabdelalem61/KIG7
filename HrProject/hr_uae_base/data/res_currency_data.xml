<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- USD: the code-defined company currency (HR_UAE_COMPANY_CURRENCY_XMLID).
         AED: the local currency, kept active for AED-denominated contracts. -->
    <record id="base.USD" model="res.currency">
        <field name="active" eval="True"/>
    </record>
    <record id="base.AED" model="res.currency">
        <field name="active" eval="True"/>
    </record>
</odoo>
