<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        UAE public holidays modelled as global time-off on the UAE calendar.
        Dates here are static placeholders for the current Gregorian year and
        are intended to be reviewed/extended yearly by HR (Islamic holidays
        shift each year). This avoids depending on OCA calendar_public_holiday.
    -->

    <record id="resource_calendar_leave_uae_new_year" model="resource.calendar.leaves">
        <field name="name">New Year's Day</field>
        <field name="calendar_id" ref="resource_calendar_uae"/>
        <field name="date_from">2026-01-01 00:00:00</field>
        <field name="date_to">2026-01-01 23:59:59</field>
        <field name="time_type">leave</field>
    </record>

    <record id="resource_calendar_leave_uae_eid_fitr" model="resource.calendar.leaves">
        <field name="name">Eid Al Fitr</field>
        <field name="calendar_id" ref="resource_calendar_uae"/>
