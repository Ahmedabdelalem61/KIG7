<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <record id="module_category_hr_uae" model="ir.module.category">
        <field name="name">HR UAE Admin</field>
        <field name="description">Roles dedicated to the HR UAE Admin platform.</field>
        <field name="sequence">25</field>
    </record>

    <record id="group_hr_uae_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_hr_uae"/>
        <field name="implied_ids" eval="[(4, ref('hr.group_hr_user'))]"/>
        <field name="comment">Read access to the HR UAE Admin platform.</field>
    </record>

    <record id="group_hr_uae_document_owner" model="res.groups">
        <field name="name">Document Owner</field>
        <field name="category_id" ref="module_category_hr_uae"/>
        <field name="implied_ids" eval="[(4, ref('group_hr_uae_user'))]"/>
        <field name="comment">Sees only their own personal documents.</field>
    </record>

    <record id="group_hr_uae_finance" model="res.groups">
        <field name="name">Finance</field>
        <field name="category_id" ref="module_category_hr_uae"/>
        <field name="implied_ids" eval="[(4, ref('group_hr_uae_user'))]"/>
        <field name="comment">Finance / Payroll back-office.</field>
    </record>

    <record id="group_hr_uae_manager" model="res.groups">
        <field name="name">HR Manager</field>
        <field name="category_id" ref="module_category_hr_uae"/>
        <field name="implied_ids" eval="[(4, ref('group_hr_uae_user')), (4, ref('hr.group_hr_manager'))]"/>
        <field name="comment">Approves salary adjustments and manages all HR UAE data.</field>
    </record>

    <record id="group_hr_uae_management" model="res.groups">
        <field name="name">Management</field>
        <field name="category_id" ref="module_category_hr_uae"/>
        <field name="implied_ids" eval="[(4, ref('group_hr_uae_manager'))]"/>
        <field name="comment">Top management - read-only oversight on all HR UAE data.</field>
    </record>

</odoo>
