<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">

    <!-- Activate common currencies so the daily FX cron can update their rates
         automatically. noupdate="0" ensures this re-applies on module upgrade. -->
    <record id="base.USD" model="res.currency">
        <field name="active" eval="True"/>
    </record>
    <record id="base.EUR" model="res.currency">
        <field name="active" eval="True"/>
    </record>
    <record id="base.GBP" model="res.currency">
        <field name="active" eval="True"/>
    </record>

</odoo>
