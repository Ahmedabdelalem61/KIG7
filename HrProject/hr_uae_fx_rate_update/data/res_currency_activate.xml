<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Activate the project currencies (codes defined in
         models/res_currency.py HR_UAE_ACTIVE_CURRENCY_CODES) on every
         install/upgrade. A <function> is required: the base currency records
         are noupdate, so plain <record> overrides are skipped on upgrade. -->
    <function model="res.currency" name="_hr_uae_activate_currencies"/>

</odoo>
