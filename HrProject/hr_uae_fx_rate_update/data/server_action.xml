<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Manual "Update now": appears in the Currencies list under the
         contextual Action menu (Settings > Technical > Currencies). -->
    <record id="action_hr_uae_fx_update_now" model="ir.actions.server">
        <field name="name">Update Exchange Rates (online)</field>
        <field name="model_id" ref="base.model_res_currency"/>
        <field name="binding_model_id" ref="base.model_res_currency"/>
        <field name="state">code</field>
        <field name="code">action = model.action_hr_uae_update_rates_now()</field>
    </record>

</odoo>
