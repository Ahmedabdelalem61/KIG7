<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!-- Source URL for online rates. "%s" is replaced by the company currency
         code. Change it here to use a different provider. -->
    <record id="param_hr_uae_fx_url" model="ir.config_parameter">
        <field name="key">hr_uae_fx_rate_update.url</field>
        <field name="value">https://open.er-api.com/v6/latest/%s</field>
    </record>

</odoo>
