<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_uae_position_tree" model="ir.ui.view">
        <field name="name">hr.uae.position.list</field>
        <field name="model">hr.uae.position</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_hr_uae_position_form" model="ir.ui.view">
        <field name="name">hr.uae.position.form</field>
        <field name="model">hr.uae.position</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="sequence"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_uae_position" model="ir.actions.act_window">
        <field name="name">Positions</field>
        <field name="res_model">hr.uae.position</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
