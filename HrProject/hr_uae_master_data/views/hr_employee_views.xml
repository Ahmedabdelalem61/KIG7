<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_employee_form_uae" model="ir.ui.view">
        <field name="name">hr.employee.form.uae</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">

            <xpath expr="//field[@name='job_id']" position="after">
                <field name="rank_id"/>
                <field name="position_id"/>
                <field name="roster"/>
            </xpath>

            <xpath expr="//page[@name='public']" position="after">
                <page string="UAE Master Data" name="hr_uae_master_data">
                    <group>
                        <group string="Identification">
                            <field name="passport_id"/>
                            <field name="passport_expiry"/>
                            <field name="visa_expire"/>
                            <field name="visa_status"/>
                            <field name="country_id"/>
                            <field name="location_id"/>
                            <field name="age"/>
                        </group>
                        <group string="Employment">
                            <field name="hr_uae_status"/>
                            <field name="hr_uae_status_manual"/>
                            <field name="hr_uae_deduct_employee_paid_tickets"/>
                            <field name="first_contract_date" readonly="1"/>
                            <field name="time_of_service"/>
                            <field name="contract_wage" widget="monetary"/>
                            <field name="housing_allowance" widget="monetary"/>
                            <field name="transportation_allowance" widget="monetary"/>
                            <field name="other_allowances" widget="monetary"/>
                            <field name="annual_ticket_amount" widget="monetary"/>
                        </group>
                        <group string="Analytic">
                            <field name="project_allocation_id"
                                   context="{'default_plan_id': %(hr_uae_master_data.account_analytic_plan_project_allocation)d, 'default_company_id': company_id}"/>
                            <field name="cost_center_id"
                                   context="{'default_plan_id': %(hr_uae_master_data.account_analytic_plan_cost_center)d, 'default_company_id': company_id}"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <record id="view_hr_employee_tree_uae" model="ir.ui.view">
        <field name="name">hr.employee.list.uae</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='job_id']" position="after">
                <field name="rank_id" optional="show"/>
                <field name="passport_id" optional="hide"/>
                <field name="roster" optional="show"/>
                <field name="hr_uae_status" optional="show"/>
                <field name="visa_status" optional="hide"/>
                <field name="project_allocation_id" optional="hide"
                       context="{'default_plan_id': %(hr_uae_master_data.account_analytic_plan_project_allocation)d, 'default_company_id': company_id}"/>
                <field name="cost_center_id" optional="hide"
                       context="{'default_plan_id': %(hr_uae_master_data.account_analytic_plan_cost_center)d, 'default_company_id': company_id}"/>
            </xpath>
        </field>
    </record>

    <record id="action_hr_employee_uae" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">hr.employee</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

</odoo>
