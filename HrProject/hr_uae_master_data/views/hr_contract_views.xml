<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_contract_form_uae" model="ir.ui.view">
        <field name="name">hr.contract.form.uae</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='salary']" position="inside">
                <field name="housing_allowance" widget="monetary"/>
                <field name="transportation_allowance" widget="monetary"/>
                <field name="other_allowances" widget="monetary"/>
            </xpath>
            <xpath expr="//group[@name='yearly_benefits']" position="inside">
                <field name="currency_id" invisible="1"/>
                <field name="annual_ticket_amount" widget="monetary"/>
            </xpath>
        </field>
    </record>

</odoo>
