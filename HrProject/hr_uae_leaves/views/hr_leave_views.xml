<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_leave_form_uae" model="ir.ui.view">
        <field name="name">hr.leave.form.uae</field>
        <field name="model">hr.leave</field>
        <field name="inherit_id" ref="hr_holidays.hr_leave_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <group string="UAE Tracking">
                    <field name="hr_uae_returned"/>
                    <field name="hr_uae_alert_sent" readonly="1"/>
                </group>
            </xpath>
            <xpath expr="//header" position="inside">
                <button name="action_set_returned"
                        type="object"
                        string="Mark as Returned"
                        class="btn-primary"
                        invisible="hr_uae_returned or state != 'validate'"
                        groups="hr_uae_base.group_hr_uae_manager"/>
            </xpath>
        </field>
    </record>

</odoo>
