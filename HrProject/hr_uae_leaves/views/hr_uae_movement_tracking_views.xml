<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_uae_movement_tracking_tree" model="ir.ui.view">
        <field name="name">hr.uae.movement.tracking.list</field>
        <field name="model">hr.uae.movement.tracking</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="employee_id"/>
                <field name="movement_type"/>
                <field name="movement_date"/>
                <field name="return_date"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <record id="view_hr_uae_movement_tracking_search" model="ir.ui.view">
        <field name="name">hr.uae.movement.tracking.search</field>
        <field name="model">hr.uae.movement.tracking</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <filter name="vacation" string="Vacation" domain="[('movement_type','=','vacation')]"/>
                <filter name="special" string="Special Permit" domain="[('movement_type','=','special_permit')]"/>
                <filter name="sick" string="Sick Leave" domain="[('movement_type','=','sick_leave')]"/>
                <filter name="unpaid" string="Unpaid Leave" domain="[('movement_type','=','unpaid_leave')]"/>
                <filter name="end" string="Contract End" domain="[('movement_type','=','contract_end')]"/>
                <filter name="transfer" string="Project Transfer" domain="[('movement_type','=','project_transfer')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_type" string="Movement Type" context="{'group_by': 'movement_type'}"/>
                    <filter name="group_month" string="Month" context="{'group_by': 'movement_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_hr_uae_movement_tracking" model="ir.actions.act_window">
        <field name="name">Movement Tracking</field>
        <field name="res_model">hr.uae.movement.tracking</field>
        <field name="view_mode">list</field>
    </record>

</odoo>
