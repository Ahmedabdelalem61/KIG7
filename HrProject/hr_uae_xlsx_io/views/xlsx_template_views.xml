<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_uae_xlsx_template_list" model="ir.ui.view">
        <field name="name">hr.uae.xlsx.template.list</field>
        <field name="model">hr.uae.xlsx.template</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="model_name"/>
                <field name="allow_export"/>
                <field name="allow_import"/>
                <field name="is_predefined"/>
            </list>
        </field>
    </record>

    <record id="view_hr_uae_xlsx_template_form" model="ir.ui.view">
        <field name="name">hr.uae.xlsx.template.form</field>
        <field name="model">hr.uae.xlsx.template</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Predefined"
                            invisible="not is_predefined"/>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="model_id"
                                   options="{'no_create': True}"/>
                            <field name="model_name" invisible="1"/>
                            <field name="sequence"/>
                            <field name="active"/>
                            <field name="is_predefined" invisible="1"/>
                        </group>
                        <group string="Permissions">
                            <field name="allow_export"/>
                            <field name="allow_import"/>
                            <field name="allow_create"
                                   invisible="not allow_import"/>
                            <field name="allow_update"
                                   invisible="not allow_import"/>
                        </group>
                    </group>
                    <field name="note" placeholder="Instructions shown on the Instructions sheet…"/>
                    <field name="line_ids">
                        <list editable="bottom">
                            <field name="sequence" widget="handle"/>
                            <field name="model_id" column_invisible="1"/>
                            <field name="field_id"
                                   options="{'no_create': True}"/>
                            <field name="name" optional="show"/>
                            <field name="field_type" optional="hide"/>
                            <field name="column_label"/>
                            <field name="for_export"/>
                            <field name="for_import"/>
                            <field name="ref_only"/>
                            <field name="is_required"/>
                            <field name="is_match_key"/>
                        </list>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_uae_xlsx_template" model="ir.actions.act_window">
        <field name="name">Excel Templates</field>
        <field name="res_model">hr.uae.xlsx.template</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'active_test': False}</field>
    </record>

</odoo>
