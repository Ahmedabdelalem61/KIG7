<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_uae_audit_report_wizard_form" model="ir.ui.view">
        <field name="name">hr.uae.audit.report.wizard.form</field>
        <field name="model">hr.uae.audit.report.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="employee_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print" type="object" string="Print" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hr_uae_audit_report_wizard" model="ir.actions.act_window">
        <field name="name">Print Audit Trail</field>
        <field name="res_model">hr.uae.audit.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
