<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_hr_uae_audit_log_tree" model="ir.ui.view">
        <field name="name">hr.uae.audit.log.list</field>
        <field name="model">hr.uae.audit.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0">
                <field name="change_date"/>
                <field name="employee_id"/>
                <field name="model"/>
                <field name="field_label"/>
                <field name="old_display"/>
                <field name="new_display"/>
                <field name="change_type"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_hr_uae_audit_log_search" model="ir.ui.view">
        <field name="name">hr.uae.audit.log.search</field>
        <field name="model">hr.uae.audit.log</field>
        <field name="arch" type="xml">
            <search>
                <field name="employee_id"/>
                <field name="field_label"/>
                <field name="user_id"/>
                <field name="model"/>
                <filter name="created" string="Created" domain="[('change_type','=','create')]"/>
                <filter name="updated" string="Updated" domain="[('change_type','=','write')]"/>
                <filter name="deleted" string="Deleted" domain="[('change_type','=','unlink')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_employee" string="Employee" context="{'group_by': 'employee_id'}"/>
                    <filter name="group_user" string="Changed By" context="{'group_by': 'user_id'}"/>
                    <filter name="group_model" string="Model" context="{'group_by': 'model'}"/>
                    <filter name="group_change" string="Change Type" context="{'group_by': 'change_type'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'change_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_hr_uae_audit_log_form" model="ir.ui.view">
        <field name="name">hr.uae.audit.log.form</field>
        <field name="model">hr.uae.audit.log</field>
        <field name="arch" type="xml">
            <form create="0" edit="0">
                <sheet>
                    <group>
                        <group>
                            <field name="change_date"/>
                            <field name="user_id"/>
                            <field name="employee_id"/>
                        </group>
                        <group>
                            <field name="model"/>
                            <field name="res_id"/>
                            <field name="change_type"/>
                            <field name="field_label"/>
                            <field name="field_name"/>
                        </group>
                    </group>
                    <group string="Change">
                        <field name="old_display"/>
                        <field name="new_display"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hr_uae_audit_log" model="ir.actions.act_window">
        <field name="name">Audit Trail</field>
        <field name="res_model">hr.uae.audit.log</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
