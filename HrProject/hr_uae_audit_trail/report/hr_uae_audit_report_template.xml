<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_employee_audit_trail_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="wizard">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Audit Trail - <t t-esc="wizard.employee_id.name"/></h2>
                        <p>
                            <strong>Period: </strong>
                            <span t-esc="wizard.date_from or '-'"/> to <span t-esc="wizard.date_to or '-'"/>
                        </p>
                        <table class="table table-sm table-bordered">
                            <thead>
                                <tr>
                                    <th>Date</th>
                                    <th>Model</th>
                                    <th>Field</th>
                                    <th>Old Value</th>
                                    <th>New Value</th>
                                    <th>Change</th>
                                    <th>By</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="wizard._get_logs()" t-as="log">
                                    <tr>
                                        <td><span t-field="log.change_date"/></td>
                                        <td><span t-esc="log.model"/></td>
                                        <td><span t-esc="log.field_label"/></td>
                                        <td><span t-esc="log.old_display"/></td>
                                        <td><span t-esc="log.new_display"/></td>
                                        <td><span t-field="log.change_type"/></td>
                                        <td><span t-esc="log.user_id.name"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
