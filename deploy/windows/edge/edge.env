# LAN IPv4 of THIS machine (Ethernet 2 adapter, the default-route LAN NIC).
# Used to bind the DNS container to the LAN IP (ICS holds 0.0.0.0:53),
# and as the answer dnsmasq returns for specialtask.com / www / test.
# If this machine's IP changes, update this value and re-run:
#   docker compose -p kig7-edge -f deploy/windows/edge/docker-compose.yml up -d
EDGE_LAN_IP=192.168.1.227
